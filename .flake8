[flake8]
max-line-length = 88
extend-ignore = E203, E266, E501, W503, C901, F824, E402
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .mypy_cache,
    claude-plugins-official,
    plugins
max-complexity = 15
per-file-ignores =
    __init__.py:F401
    services/agent_worker/worker.py:E402
    services/webhook/main.py:E402
