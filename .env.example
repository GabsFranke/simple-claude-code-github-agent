# Anthropic API Key (get from https://console.anthropic.com/)
# Note: Some versions of Claude Code use ANTHROPIC_AUTH_TOKEN instead
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_AUTH_TOKEN=your_anthropic_api_key_here  # Alternative name

# Optional: Override Anthropic API settings (for alternative providers like z.ai)
# ANTHROPIC_BASE_URL=https://api.z.ai/v1
# ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.5-air
# ANTHROPIC_DEFAULT_SONNET_MODEL=glm-4.7
# ANTHROPIC_DEFAULT_OPUS_MODEL=glm-4.7

# GitHub App Authentication (required)
# Get these from your GitHub App settings
GITHUB_APP_ID=your_app_id
GITHUB_INSTALLATION_ID=your_installation_id
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
your_private_key_here
-----END RSA PRIVATE KEY-----"

# Message Queue Configuration (Redis for self-hosted)
REDIS_URL=redis://localhost:6379

# Service Configuration
PORT=8080
LOG_LEVEL=INFO

# Langfuse Observability (optional - for debugging agent traces)
# Pre-configured for self-hosted setup:
# - Access at: http://localhost:7500
# - Login: admin@example.com / admin123
LANGFUSE_PUBLIC_KEY=lf_pk_github_agent_public
LANGFUSE_SECRET_KEY=lf_sk_github_agent_secret
# LANGFUSE_HOST is set automatically in docker-compose to http://localhost:7500
