# Anthropic API Key (get from https://console.anthropic.com/)
# Note: Some versions of Claude Code use ANTHROPIC_AUTH_TOKEN instead
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_AUTH_TOKEN=your_anthropic_api_key_here  # Alternative name

# Optional: Override Anthropic API settings (for alternative providers like z.ai)
# ANTHROPIC_BASE_URL=https://api.z.ai/v1
# ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.5-air
# ANTHROPIC_DEFAULT_SONNET_MODEL=glm-4.7
# ANTHROPIC_DEFAULT_OPUS_MODEL=glm-4.7

# GitHub Personal Access Token (get from https://github.com/settings/personal-access-tokens/new)
# Required scopes: repo, workflow
GITHUB_PAT=your_github_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Message Queue Configuration
# For self-hosted/development: use "redis"
# For cloud production: use "pubsub"
QUEUE_TYPE=redis
REDIS_URL=redis://localhost:6379

# GCP Configuration (for production with Pub/Sub)
GCP_PROJECT_ID=your-gcp-project
PUBSUB_TOPIC=agent-requests
PUBSUB_SUBSCRIPTION=agent-requests-sub

# Service Configuration
PORT=8080
LOG_LEVEL=INFO

# Local Testing
TEST_REPO=owner/repo
TEST_ISSUE=1
TEST_COMMAND=/agent create a PR for this
